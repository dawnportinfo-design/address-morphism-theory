      "failureBehaviors": [
        { "trigger": "alias collision", "action": "candidate-only", "blocksVerifiedIssuance": true },
        { "trigger": "low language confidence", "action": "manual-review", "blocksVerifiedIssuance": true },
        { "trigger": "missing source alias", "action": "additional-evidence-required", "blocksVerifiedIssuance": true }
      ],
      "safeWording": "Multilingual expansion is a recall layer; identity decisions require secondary structure, source, and history gates.",
      "forbiddenClaim": "Translation proves two address strings are the same address."
