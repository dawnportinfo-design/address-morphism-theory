{
  "schema": "amt-s-priority-decomposition-gate-v1",
  "updatedAt": "2026-06-29",
  "purpose": "Decompose S-priority unverified AMT claims by region, use case, data source, and failure behavior so the repository can verify claim boundaries without pretending that worldwide empirical completeness is already proven.",
  "items": [
    {
      "id": "candidate-generation-world-coverage",
      "claim": "Worldwide candidate generation completeness",
      "regions": ["dense formal postal regions", "weak postal rural regions", "no-normal-postcode urban regions", "island and coastal regions", "disputed or cross-border policy regions"],
      "useCases": ["international delivery", "e-commerce checkout", "field handoff", "hotel or POS intake"],
      "dataSources": [
        { "name": "official postal and administrative data", "approval": "local-static" },
        { "name": "open geo data", "approval": "public-oss" },
        { "name": "redacted feedback envelopes", "approval": "local-fixture" }
      ],
      "metrics": ["recall@k", "candidate-miss-rate", "unresolved-rate", "source-coverage-rate"],
      "failureBehaviors": [
        { "trigger": "target not in candidate set", "action": "unresolved", "blocksVerifiedIssuance": true },
        { "trigger": "near-tied candidates", "action": "manual-review", "blocksVerifiedIssuance": true },
        { "trigger": "source stale or unlicensed", "action": "additional-evidence-required", "blocksVerifiedIssuance": true }
      ],
      "safeWording": "Candidate generation is source-bound and region-measured; insufficient coverage returns unresolved or additional evidence required.",
      "forbiddenClaim": "AMT can find every addressable object worldwide."
    },
    {
      "id": "multilingual-search-recall",
      "claim": "Multilingual search recall improvement",
      "regions": ["multi-script regions", "Latin transliteration regions", "historical-name regions", "cross-border naming regions"],
